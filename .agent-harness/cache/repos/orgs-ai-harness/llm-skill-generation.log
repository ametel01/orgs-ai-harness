from pathlib import Path
import re
roots = [Path('org-agent-skills/repos/orgs-ai-harness/llm-output/codex/skills'), Path('org-agent-skills/repos/orgs-ai-harness/llm-output/claude/skills')]
name_re = re.compile(r'"'^[a-z0-9]+(?:-[a-z0-9]+)*$'"')
errors = []
for root in roots:
    if not root.is_dir():
        errors.append(f'missing root: {root}')
        continue
    for skill_dir in sorted(p for p in root.iterdir() if p.is_dir()):
        skill_file = skill_dir / 'SKILL.md'
        if not skill_file.is_file():
            errors.append(f'missing SKILL.md: {skill_dir}')
            continue
        text = skill_file.read_text(encoding='utf-8')
        lines = text.splitlines()
        if not lines or lines[0].strip() "'!= '"'---':
            errors.append(f'missing frontmatter start: {skill_file}')
            continue
        front = {}
        end = None
        for i, line in enumerate(lines[1:], start=1):
            if line.strip() == '---':
                end = i
                break
            if ':' not in line:
                errors.append(f'invalid frontmatter line: {skill_file}:{i+1}')
                continue
            key, value = line.split(':', 1)
            front[key.strip()] = value.strip()
        if end is None:
            errors.append(f'missing frontmatter end: {skill_file}')
            continue
        name = front.get('name')
        desc = front.get('description')
        if name "'!= skill_dir.name:
            errors.append(f'"'name mismatch: {skill_file} name={name"'!r} dir={skill_dir.name!r}'"')
        if not name or len(name) > 64 or not name_re.fullmatch(name):
            errors.append(f'invalid name: {skill_file} name={name"'!r}'"')
        if not desc or len(desc) > 1024:
            errors.append(f'invalid description length: {skill_file} len={len(desc or \"\")}')
        if desc and 'Use this skill when' not in desc:
            errors.append(f'description not trigger-focused: {skill_file}')
        if not ''.join(lines[end+1:]).strip():
            errors.append(f'missing markdown body: {skill_file}')
print('manual validation passed' if not errors else 'manual validation failed')
for error in errors:
    print(error)
raise SystemExit(1 if errors else 0)
