            key={item.href}
            href={item.href}
            className="side-link"
            aria-current={active ? "page" : undefined}
          >
            <span className="glyph" aria-hidden="true">
              {item.glyph}
            </span>
            <span>{item.label}</span>
          </Link>
        );
      })}
    </nav>
  );
}
