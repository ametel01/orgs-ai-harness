const PositiveNumber = z.number().finite().positive();
const Ratio = z.number().finite().min(0).max(1);

export const HRZoneNameSchema = z.enum(HR_ZONE_ORDER);

export const WorkoutSummarySchema = z.object({
  id: z.string(),
