/bin/zsh -lc "pwd && ruby -ryaml -e '
roots = ARGV
errors = []
roots.each do |root|
  dirs = Dir.children(root).map { |n| File.join(root, n) }.select { |p| File.directory?(p) }.sort
  dirs.each do |dir|
    skill = File.join(dir, \"SKILL.md\")
    unless File.file?(skill)
      errors << \"missing SKILL.md: #{dir}\"
      next
    end
    text = File.read(skill)
    unless text.start_with?(\"---\\n\")
      errors << \"missing opening frontmatter: #{skill}\"
      next
    end
    parts = text.split(/"'^---'"\\s*"'$/, 3)
    if parts.length < 3
      errors << "invalid frontmatter delimiters: #{skill}"
      next
    end
    begin
      fm = YAML.safe_load(parts[1], permitted_classes: [], aliases: false)
    rescue => e
      errors << "YAML parse failed #{skill}: #{e.message}"
      next
    end
    name = fm["name"]
    desc = fm["description"]
    parent = File.basename(dir)
    errors << "name mismatch #{skill}: #{name.inspect} != #{parent.inspect}" unless name == parent
    errors << "bad name #{skill}: #{name.inspect}" unless name.is_a?(String) && name.length.between?(1,64) && name.match?(/'"\\A[a-z0-9]+(?:-[a-z0-9]+)*\\z/)
    errors << \"bad description #{skill}\" unless desc.is_a?(String) && desc.length.between?(1,1024)
    allowed = %w[name description license compatibility metadata allowed-tools]
    extra = fm.keys - allowed
    errors << \"unknown frontmatter keys #{skill}: #{extra.join(\",\")}\" unless extra.empty?
  end
end
if errors.empty?
  puts \"manual validation passed for #{roots.join(\", \")}\" 
else
  warn errors.join(\"\\n\")
  exit 1
end
