			},
		},
	}

	_, err := refreshVerifiedTools(context.Background(), registry, &st, fakeRuntimeVerifier{})
	if err != nil {
		t.Fatalf("refreshVerifiedTools() error = %v", err)
	}

	receipt, ok := st.Tool("jq")
	if !ok {
		t.Fatal("state.Tool(\"jq\") not found")
	}

	if receipt.BinaryPath != "" {
