        for line in fm.splitlines():
            if not line.strip():
                continue
            if line.startswith('  ') and current_key:
                continue
            if ':' not in line:
                errors.append(f'{f}: invalid yaml-ish line {line"'!r}'"')
                continue
            k,v=line.split(':',1)
            current_key=k.strip()
            data[current_key]=v.strip().strip('\"\\'')
        name=data.get('name')
        desc=data.get('description')
        if not name:
            errors.append(f'{f}: missing name')
        elif name "'!= skill_dir.name:
            errors.append(f'"'{f}: name {name"'!r} does not match parent {skill_dir.name!r}'"')
        elif len(name)>64 or not name_re.match(name):
            errors.append(f'{f}: invalid name {name"'!r}'"')
        if desc is None:
            errors.append(f'{f}: missing description')
        elif not (1 <= len(desc) <= 1024):
            errors.append(f'{f}: description length {len(desc)} invalid')
        summary.append((root.name, skill_dir.name, len(desc or '')))
if errors:
    print('VALIDATION FAILED')
    for e in errors:
        print(e)
    raise SystemExit(1)
print('manual validation passed')
for item in summary:
    print(f'{item[0]}/{item[1]} description_chars={item[2]}')
