services:
  # ===========================================================================
  # PostgreSQL - Indexer Database
  # ===========================================================================
  postgres:
    image: postgres:16-alpine
    container_name: horizon-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: horizon
      POSTGRES_PASSWORD: horizon
      POSTGRES_DB: horizon_indexer
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U horizon -d horizon_indexer"]
      interval: 2s
      timeout: 5s
      retries: 10
    networks:
      - yield-network

  # ===========================================================================
  # Database Migrations - Applies Drizzle migrations on startup
  # ===========================================================================
  indexer-migrate:
    build:
      context: ./packages/indexer
      dockerfile: Dockerfile.migrate
    container_name: indexer-migrate
    environment:
      POSTGRES_CONNECTION_STRING: postgres://horizon:horizon@postgres:5432/horizon_indexer
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - yield-network

  # ===========================================================================
  # Apibara DNA Stack - Required for local indexer (optional)
  # ===========================================================================
  etcd:
    image: quay.io/coreos/etcd:v3.6.7
    container_name: horizon-etcd
    restart: unless-stopped
    environment:
      - ETCD_LISTEN_CLIENT_URLS=http://0.0.0.0:2379
      - ETCD_ADVERTISE_CLIENT_URLS=http://etcd:2379
    ports:
      - "2379:2379"
    volumes:
      - etcd_data:/etcd-data
    command:
      - etcd
      - --data-dir=/etcd-data
    healthcheck:
      test: ["CMD", "etcdctl", "endpoint", "health"]
      interval: 10s
      timeout: 5s
      retries: 5
    profiles: ["indexer"]
    networks:
      - yield-network

  minio:
    image: minio/minio:latest
    container_name: horizon-minio
    restart: unless-stopped
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - minio_data:/data
    environment:
      MINIO_ROOT_USER: minioadmin
      MINIO_ROOT_PASSWORD: minioadmin
    command: ["server", "/data", "--console-address", ":9001"]
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 5
    profiles: ["indexer"]
    networks:
      - yield-network

  minio-setup:
    image: minio/mc:latest
    container_name: horizon-minio-setup
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      mc alias set myminio http://minio:9000 minioadmin minioadmin;
      mc mb myminio/dna-data --ignore-existing;
      exit 0;
      "
    profiles: ["indexer"]
    networks:
      - yield-network

  dna-starknet:
    image: apibara-dna-starknet:latest
    container_name: horizon-dna-starknet
    restart: unless-stopped
    ports:
      - "7171:7007"
    volumes:
      - dna_cache:/cache
    environment:
      RUST_LOG: info
      STARKNET_RPC_URL: http://devnet:5050
      DNA_S3_BUCKET: dna-data
      DNA_S3_ENDPOINT: http://minio:9000
      DNA_S3_REGION: us-east-1
      AWS_ACCESS_KEY_ID: minioadmin
      AWS_SECRET_ACCESS_KEY: minioadmin
      DNA_ETCD_ENDPOINTS: http://etcd:2379
      DNA_ETCD_PREFIX: /dna/starknet
      DNA_INGESTION_ENABLED: "true"
      DNA_COMPACTION_ENABLED: "true"
      DNA_SERVER_ENABLED: "true"
      DNA_INGESTION_MAX_CONCURRENT_TASKS: "1"
      DNA_SERVER_ADDRESS: "0.0.0.0:7007"
      DNA_CACHE_DIR: /cache
      DNA_CACHE_DATA_DISK_SIZE: 5Gi
      DNA_CACHE_INDEX_DISK_SIZE: 5Gi
      STARKNET_NO_INGEST_PENDING: "true"
      DNA_INGESTION_DANGEROUSLY_OVERRIDE_STARTING_BLOCK: "0"
    command: ["start"]
    depends_on:
      devnet:
        condition: service_healthy
      minio-setup:
        condition: service_completed_successfully
      etcd:
        condition: service_healthy
    profiles: ["indexer"]
    networks:
      - yield-network

  # ===========================================================================
  # Indexer - Apibara indexers running against local devnet
  # ===========================================================================
  indexer:
    build:
      context: ./packages/indexer
      dockerfile: Dockerfile
    container_name: horizon-indexer
    environment:
      PRESET: devnet
      DNA_STREAM_URL: http://dna-starknet:7007
      POSTGRES_CONNECTION_STRING: postgres://horizon:horizon@postgres:5432/horizon_indexer
      DATABASE_URL: postgres://horizon:horizon@postgres:5432/horizon_indexer
    depends_on:
      postgres:
        condition: service_healthy
      dna-starknet:
        condition: service_started
      indexer-migrate:
        condition: service_completed_successfully
    profiles: ["indexer"]
    networks:
      - yield-network

  # ===========================================================================
  # Starknet Devnet - Local Starknet Development Network
  # ===========================================================================
  devnet:
    image: shardlabs/starknet-devnet-rs:0.7.1-seed0
    container_name: starknet-devnet
    ports:
      - "5050:5050"
    environment:
      - HOST=0.0.0.0
      - PORT=5050
      - SEED=0
      - PREDECLARE_ARGENT=true
      - BLOCK_GENERATION_ON=10 # Generate new block every 10 seconds for yield simulation
    healthcheck:
      test:
        [
          "CMD-SHELL",
          "wget -q --spider http://127.0.0.1:5050/is_alive || exit 1",
        ]
      interval: 2s
      timeout: 5s
      retries: 60
      start_period: 5s
    networks:
      - yield-network

  # ===========================================================================
  # Deployer - Builds and deploys contracts
  # ===========================================================================
  deployer:
    build:
      context: .
      dockerfile: docker/Dockerfile.deployer
    container_name: deployer
    environment:
      - DEVNET_URL=http://devnet:5050
      - ENV_FILE=.env.devnet
      # Liquidity seeding (default: 10,000 tokens per market)
      - SEED_LIQUIDITY=true
      - SEED_LIQUIDITY_AMOUNT=1000000000000000000000000
      # Market anchors are read from .env.devnet (mounted below):
      #   MARKET_INITIAL_ANCHOR_NST_STRK (~8% APY)
      #   MARKET_INITIAL_ANCHOR_SSTRK (~6% APY)
    volumes:
      # Mount output directory for addresses
      - ./deploy/addresses:/output
      - ./.env.devnet:/app/.env.devnet
    depends_on:
      devnet:
        condition: service_healthy
    networks:
      - yield-network

volumes:
  postgres_data:
  minio_data:
  dna_cache:
  etcd_data:

networks:
  yield-network:
    driver: bridge
services:
  # ===========================================================================
  # Starknet Devnet - Fork Mode (Mainnet Fork)
  # ===========================================================================
  devnet:
    image: shardlabs/starknet-devnet-rs:0.7.1-seed0
    container_name: starknet-devnet-fork
    ports:
      - "5050:5050"
    environment:
      - FORK_NETWORK=https://starknet-mainnet.g.alchemy.com/starknet/version/rpc/v0_10/usuQSZ2cdSmSR8rNpstjp
    healthcheck:
      test:
        [
          "CMD-SHELL",
          "wget -q --spider http://127.0.0.1:5050/is_alive || exit 1",
        ]
      interval: 5s
      timeout: 10s
      retries: 60
      start_period: 30s
    networks:
      - fork-network

  # ===========================================================================
  # Deployer - Builds and deploys contracts on forked network
  # ===========================================================================
  deployer:
    build:
      context: .
      dockerfile: docker/Dockerfile.deployer
    container_name: deployer-fork
    environment:
      - DEVNET_URL=http://devnet:5050
      - ENV_FILE=.env.fork
      - DEPLOY_SCRIPT=deploy-fork.sh
      - SEED_LIQUIDITY=false
    volumes:
      - ./deploy/addresses:/output
      - ./.env.fork:/app/.env.fork
    depends_on:
      devnet:
        condition: service_healthy
    networks:
      - fork-network

networks:
  fork-network:
    driver: bridge
